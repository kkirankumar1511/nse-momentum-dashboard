# --- Kite Connect (required) ---
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# --- LLM provider (open-source by default) ---
# ollama     = local, free, private. Install https://ollama.com then:
#                ollama pull qwen2.5:14b-instruct
# groq       = hosted open weights, free tier  -> set LLM_API_KEY
# openrouter = free open models (":free" ids)  -> set LLM_API_KEY
# together   = cheap hosted open models        -> set LLM_API_KEY
# anthropic  = paid fallback                   -> set ANTHROPIC_API_KEY
LLM_PROVIDER=ollama
LLM_MODEL=
LLM_BASE_URL=
LLM_API_KEY=
LLM_CONTEXT=
LLM_TIMEOUT=300

# Optional paid fallback only
ANTHROPIC_API_KEY=
